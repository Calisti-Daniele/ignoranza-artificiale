# DATABASE_URL is injected by docker-compose (local) or the cloud provider (production).
# Do not set it here.
REDIS_URL=redis://redis:6379/0
OPENROUTER_API_KEY=your_openrouter_api_key_here
CORS_ORIGINS=["http://localhost:3000"]
HTTPS_ENABLED=false

# ALLOWED_HOSTS — MUST be set in production. List of trusted Host header values.
# Example: ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com
# In local development: ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# DOCS_ENABLED — Set to true only in development. Keep false (or unset) in production
# to prevent exposing the full API schema via /api/docs, /api/redoc, /api/openapi.json.
DOCS_ENABLED=true
