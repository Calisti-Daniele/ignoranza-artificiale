# === SVILUPPO LOCALE ===
API_INTERNAL_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# === PRODUZIONE (DigitalOcean App Platform) ===
# URL privata del servizio backend (assegnata da DO App Platform).
# Nella app spec DO, imposta questa variabile con scope: RUN_TIME.
# Il formato della private URL e': http://<app-name>.private:<port>
# Esempio: http://ignoranza-artificiale.private:8000
# API_INTERNAL_URL=http://${APP_NAME}.private:8000

# URL pubblica del backend (per il CSP header connect-src nel browser).
# Necessaria SOLO se il browser deve raggiungere il backend direttamente.
# Con il proxy server-side (src/app/api/v1/[...path]/route.ts) attivo,
# lascia vuota: il browser parla solo con 'self' (Next.js).
# Scope DO: BUILD_TIME (viene inclusa nel bundle al momento del build).
# NEXT_PUBLIC_API_URL=
